+/*
+ * Aspeed AST2600 "johnblue" – QEMU BMC for I2C→MCTP→PLDM development
+ *
+ * Clones the AST2600 EVB machine and places an MCTP-over-SMBus endpoint
+ * device on I2C bus 1 at address 0x0f.  This mirrors the kernel DTS patch
+ * that adds mctp-controller to &i2c1 and the mctp-setup-i2c.service that
+ * creates the mctpi2c1 netdev on bus 1.
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#include "qemu/osdep.h"
+#include "qapi/error.h"
+#include "hw/arm/machines-qom.h"
+#include "hw/arm/aspeed.h"
+#include "hw/arm/aspeed_soc.h"
+#include "hw/i2c/smbus_eeprom.h"
+#include "hw/sensor/tmp105.h"
+#include "hw/i2c/mctp_i2c_endpoint.h"
+
+/* Reuse AST2600 EVB strap values */
+#define JOHNBLUE_HW_STRAP1  0x000000C0
+#define JOHNBLUE_HW_STRAP2  0x00000003
+
+/*
+ * I2C bus 1 (0-indexed) is the bus the kernel's mctp-i2c driver manages.
+ * The DTS patch adds "mctp-controller" to &i2c1, which makes the kernel
+ * create the mctpi2c1 netdev on bus index 1.
+ *
+ * TERMINUS_I2C_ADDR 0x0f must match the value written by mctp-setup-i2c.service:
+ *   echo "mctp-i2c-interface 0x0f" > /sys/bus/i2c/devices/i2c-1/new_device
+ */
+#define MCTP_I2C_BUS        1
+#define TERMINUS_I2C_ADDR   0x0f
+
+static void johnblue_i2c_init(AspeedMachineState *bmc)
+{
+    AspeedSoCState *soc = bmc->soc;
+
+    /* Keep the EVB EEPROM on bus 7 and TMP105 on bus 8 (inherited from EVB) */
+    uint8_t *eeprom_buf = g_malloc0(8 * 1024);
+    smbus_eeprom_init_one(aspeed_i2c_get_bus(&soc->i2c, 7), 0x50, eeprom_buf);
+    i2c_slave_create_simple(aspeed_i2c_get_bus(&soc->i2c, 8),
+                            TYPE_TMP105, 0x4d);
+
+    /*
+     * Place the MCTP/PLDM endpoint on I2C bus 1 at address 0x0f.
+     * The kernel's mctp-i2c-interface slave driver binds at this address
+     * and the mctp-i2c master driver uses it as the terminus I2C address.
+     */
+    i2c_slave_create_simple(aspeed_i2c_get_bus(&soc->i2c, MCTP_I2C_BUS),
+                            TYPE_MCTP_I2C_ENDPOINT, TERMINUS_I2C_ADDR);
+}
+
+static void aspeed_machine_johnblue_class_init(ObjectClass *oc,
+                                               const void *data)
+{
+    MachineClass *mc      = MACHINE_CLASS(oc);
+    AspeedMachineClass *amc = ASPEED_MACHINE_CLASS(oc);
+
+    mc->desc        = "Aspeed AST2600 johnblue BMC – MCTP/PLDM development";
+    amc->soc_name   = "ast2600-a3";
+    amc->hw_strap1  = JOHNBLUE_HW_STRAP1;
+    amc->hw_strap2  = JOHNBLUE_HW_STRAP2;
+    amc->fmc_model  = "w25q512jv";
+    amc->spi_model  = "w25q512jv";
+    amc->num_cs     = 1;
+    amc->macs_mask  = ASPEED_MAC0_ON | ASPEED_MAC1_ON |
+                      ASPEED_MAC2_ON | ASPEED_MAC3_ON;
+    amc->sdhci_wp_inverted = true;
+    amc->i2c_init   = johnblue_i2c_init;
+    mc->default_ram_size = 1 * GiB;
+    aspeed_machine_class_init_cpus_defaults(mc);
+    aspeed_machine_ast2600_class_emmc_init(oc);
+}
+
+static const TypeInfo aspeed_ast2600_johnblue_types[] = {
+    {
+        .name       = MACHINE_TYPE_NAME("ast2600-johnblue"),
+        .parent     = TYPE_ASPEED_MACHINE,
+        .class_init = aspeed_machine_johnblue_class_init,
+        .interfaces = arm_machine_interfaces,
+    }
+};
+
+DEFINE_TYPES(aspeed_ast2600_johnblue_types)
